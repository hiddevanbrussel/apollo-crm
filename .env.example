# ---------------------------------------------------------------------------
# Apollo CRM environment configuration
# Copy this file to ".env" and adjust the values before running docker compose.
# ---------------------------------------------------------------------------

# --- PostgreSQL ---
POSTGRES_USER=apollo
POSTGRES_PASSWORD=apollo
POSTGRES_DB=apollo_crm
POSTGRES_PORT=5432

# Secret used to sign JWT access tokens. Use a long random string in production.
JWT_SECRET=change_me_super_secret
JWT_EXPIRE_MINUTES=1440

# Fernet key used to encrypt the Apollo API key at rest.
# Leave empty to auto-derive a key from JWT_SECRET (fine for local dev).
# Generate a proper one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Default Apollo API base URL (configurable in the app afterwards).
APOLLO_BASE_URL=https://api.apollo.io

# Waterfall enrichment queries third-party sources and may share data with Apollo.
# Leave false unless you explicitly want async email/phone lookup via webhook.
APOLLO_WATERFALL_ENABLED=false

# Public URL for Apollo waterfall webhooks (only needed when APOLLO_WATERFALL_ENABLED=true).
# PUBLIC_BASE_URL=https://ai.xential.nl

# Comma separated list of allowed CORS origins for the frontend.
# Production (same-origin via nginx proxy): set to your public URL, e.g. https://ai.xential.nl
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# --- Seed / default admin account ---
SEED_ON_START=true
ADMIN_EMAIL=admin@apollo-crm.com
ADMIN_PASSWORD=admin123

# --- Frontend ---
FRONTEND_PORT=8080
# API base URL baked into the frontend at build time.
# Production default: /api (nginx proxies to backend).
# Local Vite dev: http://localhost:8000/api
VITE_API_URL=
