# ---------------------------------------------------------------------------
# Apollo CRM environment configuration
# Copy this file to ".env" and adjust the values before running docker compose.
# ---------------------------------------------------------------------------

# --- PostgreSQL ---
POSTGRES_USER=apollo
POSTGRES_PASSWORD=apollo
POSTGRES_DB=apollo_crm
POSTGRES_PORT=5432

# --- Backend ---
BACKEND_PORT=8000

# Secret used to sign JWT access tokens. Use a long random string in production.
JWT_SECRET=change_me_super_secret
JWT_EXPIRE_MINUTES=1440

# Fernet key used to encrypt the Apollo API key at rest.
# Leave empty to auto-derive a key from JWT_SECRET (fine for local dev).
# Generate a proper one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Default Apollo API base URL (configurable in the app afterwards).
APOLLO_BASE_URL=https://api.apollo.io

# Comma separated list of allowed CORS origins for the frontend.
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# --- Seed / default admin account ---
SEED_ON_START=true
ADMIN_EMAIL=admin@apollo-crm.com
ADMIN_PASSWORD=admin123

# --- Frontend ---
FRONTEND_PORT=8080
# Base URL the frontend uses to reach the backend API (baked at build time).
VITE_API_URL=http://localhost:8000
